{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg0": "#06101e",
    "bg1": "#031B26",
    "bg2": "#052839",
    "border0": "#06364B",
    "border1": "#08435E",
    "cyanBright": "#66def9",
    "cyan": "#008DA3",
    "cyanDim": "#006A7A",
    "cyanDark": "#004752",
    "sky": "#35b5ff",
    "orange": "#fd5e3a",
    "text": "#e2d9c5",
    "mutedBlue": "#22536f",
    "diffAddedBg": "#162826",
    "diffRemovedBg": "#241822"
  },
  "theme": {
    "primary": {
      "dark": "cyanBright",
      "light": "cyan"
    },
    "secondary": {
      "dark": "sky",
      "light": "sky"
    },
    "accent": {
      "dark": "orange",
      "light": "orange"
    },
    "error": {
      "dark": "orange",
      "light": "orange"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "sky",
      "light": "sky"
    },
    "info": {
      "dark": "cyan",
      "light": "cyan"
    },
    "text": {
      "dark": "text",
      "light": "text"
    },
    "textMuted": {
      "dark": "cyanBright",
      "light": "cyanBright"
    },
    "background": {
      "dark": "bg0",
      "light": "bg0"
    },
    "backgroundPanel": {
      "dark": "bg1",
      "light": "bg1"
    },
    "backgroundElement": {
      "dark": "bg2",
      "light": "bg2"
    },
    "border": {
      "dark": "border0",
      "light": "border0"
    },
    "borderActive": {
      "dark": "border1",
      "light": "border1"
    },
    "borderSubtle": {
      "dark": "bg2",
      "light": "bg2"
    },
    "diffAdded": {
      "dark": "sky",
      "light": "sky"
    },
    "diffRemoved": {
      "dark": "orange",
      "light": "orange"
    },
    "diffContext": {
      "dark": "mutedBlue",
      "light": "mutedBlue"
    },
    "diffHunkHeader": {
      "dark": "border0",
      "light": "border0"
    },
    "diffHighlightAdded": {
      "dark": "sky",
      "light": "sky"
    },
    "diffHighlightRemoved": {
      "dark": "orange",
      "light": "orange"
    },
    "diffAddedBg": {
      "dark": "diffAddedBg",
      "light": "diffAddedBg"
    },
    "diffRemovedBg": {
      "dark": "diffRemovedBg",
      "light": "diffRemovedBg"
    },
    "diffContextBg": {
      "dark": "bg1",
      "light": "bg1"
    },
    "diffLineNumber": {
      "dark": "mutedBlue",
      "light": "text"
    },
    "diffAddedLineNumberBg": {
      "dark": "diffAddedBg",
      "light": "diffAddedBg"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diffRemovedBg",
      "light": "diffRemovedBg"
    },
    "markdownText": {
      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "cyanBright",
      "light": "cyan"
    },
    "markdownLink": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownLinkText": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownCode": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownBlockQuote": {
      "dark": "mutedBlue",
      "light": "mutedBlue"
    },
    "markdownEmph": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownStrong": {
      "dark": "cyanBright",
      "light": "cyanBright"
    },
    "markdownHorizontalRule": {
      "dark": "border0",
      "light": "border0"
    },
    "markdownListItem": {
      "dark": "cyanBright",
      "light": "cyan"
    },
    "markdownListEnumeration": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownImage": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownImageText": {
      "dark": "sky",
      "light": "sky"
    },
    "markdownCodeBlock": {
      "dark": "text",
      "light": "text"
    },
    "syntaxComment": {
      "dark": "mutedBlue",
      "light": "mutedBlue"
    },
    "syntaxKeyword": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxFunction": {
      "dark": "sky",
      "light": "sky"
    },
    "syntaxVariable": {
      "dark": "cyanBright",
      "light": "cyanBright"
    },
    "syntaxString": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxNumber": {
      "dark": "cyanBright",
      "light": "cyanBright"
    },
    "syntaxType": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxOperator": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxPunctuation": {
      "dark": "orange",
      "light": "orange"
    }
  }
}
